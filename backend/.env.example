NODE_ENV=development
PORT=4000
CLIENT_URL=http://localhost:5173
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/chatsphere_rebuild?schema=public
JWT_ACCESS_SECRET=replace_with_a_long_random_secret_value_123456
JWT_REFRESH_SECRET=replace_with_another_long_random_secret_value_123456
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL_DAYS=30
GOOGLE_CLIENT_ID=
UPLOAD_DIR=./storage/private
MAX_UPLOAD_SIZE_MB=10
ENABLE_MOCK_AI=true
AI_PROVIDER=mock
AI_DEFAULT_MODEL=mock-general
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=120
